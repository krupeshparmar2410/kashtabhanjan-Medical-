# Port number for the Express server to listen on
PORT=5000

# Primary MongoDB URI. Supports Atlas URI or a local URI.
# In production offline environment, this should default to local MongoDB: mongodb://127.0.0.1:27017/medical_shop
MONGO_URI=mongodb://127.0.0.1:27017/medical_shop

# JSON Web Token secret key for session signing. Must be a strong unique key in production.
JWT_SECRET=your_jwt_secret_key_change_me_in_production

# JWT expiration time. Recommended formats: '24h', '7d', etc.
JWT_EXPIRE=24h

# Environment: 'production', 'development', or 'test'. Gated logic depends on this.
NODE_ENV=production

# Encryption key used for backup protection. Must be at least 32 characters long.
BACKUP_ENCRYPTION_KEY=must_be_at_least_32_characters_long_backup_key
