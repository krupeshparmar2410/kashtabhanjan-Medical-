{
  "openapi": "3.0.0",
  "info": {
    "title": "Kashtbhanjan Medical Shop Management System API",
    "description": "Enterprise-grade Pharmacy ERP API documentation covering Sales POS, FEFO Inventory, Suppliers, Customers, and System Maintenance Utilities.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5000/api",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter JWT Bearer token to authorize requests."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string", "example": "Invalid request parameters" }
        }
      },
      "DatabaseStats": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "stats": {
            "type": "object",
            "properties": {
              "totalCollections": { "type": "integer", "example": 33 },
              "totalRecords": { "type": "integer", "example": 1420 },
              "archivedCount": { "type": "integer", "example": 12 },
              "lastBackupTime": { "type": "string", "format": "date-time", "example": "2026-06-16T12:00:00.000Z" },
              "lastRestoreTime": { "type": "string", "format": "date-time", "example": "2026-06-16T12:30:00.000Z" },
              "failedBackupCount": { "type": "integer", "example": 0 },
              "failedTransactionCount": { "type": "integer", "example": 2 },
              "totalLogs": { "type": "integer", "example": 150 }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Authenticate User",
        "description": "Returns a JWT token for authenticated admin or staff.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "admin@kashtbhanjan.com" },
                  "password": { "type": "string", "example": "admin123" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "token": { "type": "string", "example": "eyJhbGciOiJIUzI1NiIsIn..." },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "example": "664c12ef0d27..." },
                        "name": { "type": "string", "example": "Krupesh Admin" },
                        "role": { "type": "string", "example": "admin" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid email or password",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      }
    },
    "/settings/stats": {
      "get": {
        "summary": "Get Database Statistics",
        "description": "Returns counts of collections, records, logs, backups, and failures for the maintenance console dashboard. (Admin role required)",
        "responses": {
          "200": {
            "description": "Database statistics loaded successfully",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DatabaseStats" } } }
          },
          "401": { "description": "Unauthorized - JWT token missing or invalid" },
          "403": { "description": "Forbidden - Only Admin role allowed" }
        }
      }
    },
    "/settings/backups": {
      "get": {
        "summary": "List Backups",
        "description": "Returns a list of all database backups and their metadata (Admin only)",
        "responses": {
          "200": {
            "description": "Success response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "backups": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "_id": { "type": "string" },
                          "backupId": { "type": "string" },
                          "backupType": { "type": "string" },
                          "fileName": { "type": "string" },
                          "fileSize": { "type": "integer" },
                          "checksum": { "type": "string" },
                          "status": { "type": "string" },
                          "createdAt": { "type": "string" },
                          "fileExistsOnDisk": { "type": "boolean" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Backup",
        "description": "Acquires a system lock and triggers database backup (Full or Incremental).",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "backupType": { "type": "string", "enum": ["Full", "Incremental"], "default": "Full" },
                  "notes": { "type": "string", "example": "Scheduled weekly snapshot" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Backup created successfully" },
          "409": { "description": "Conflict - Backup lock already active" }
        }
      }
    },
    "/settings/restore": {
      "post": {
        "summary": "Restore Database from Backup File",
        "description": "Acquires a distributed lock, checks SHA-256 integrity checksum, clears database and restores collections. Rolls back safely on failure.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fileName": { "type": "string", "example": "backup_BKP000001_2026-06-16T12-00-00.json" }
                },
                "required": ["fileName"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Database successfully restored" },
          "400": { "description": "Bad Request - Checksum mismatch or corrupted file" },
          "409": { "description": "Conflict - Maintenance operations lock active" }
        }
      }
    },
    "/settings/archive": {
      "post": {
        "summary": "Soft-Archive Old Records",
        "description": "Finds Sales, Returns, Payments, and Audit Logs older than cutoff date and marks them as isArchived: true.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cutoffDate": { "type": "string", "format": "date", "example": "2025-06-16" }
                },
                "required": ["cutoffDate"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Archiving sweep successfully completed" }
        }
      }
    },
    "/settings/archive/restore": {
      "post": {
        "summary": "Restore Soft-Archived Records",
        "description": "Restores soft-archived records back to active views.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "collectionName": { "type": "string", "example": "Sale" },
                  "cutoffDate": { "type": "string", "example": "2025-06-16" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Archived records restored successfully" }
        }
      }
    },
    "/settings/archive/purge": {
      "delete": {
        "summary": "Permanently Purge Archived Records",
        "description": "Super Admin only. Physically deletes all isArchived: true records from MongoDB.",
        "responses": {
          "200": { "description": "Permanently purged documents" },
          "403": { "description": "Forbidden - Admin access required" }
        }
      }
    },
    "/settings/logs/download": {
      "get": {
        "summary": "Download Log Files",
        "description": "Downloads the raw Winston error.log or combined.log from the server.",
        "parameters": [
          {
            "name": "logType",
            "in": "query",
            "schema": { "type": "string", "enum": ["combined", "error"], "default": "combined" }
          }
        ],
        "responses": {
          "200": { "description": "Logs file download" }
        }
      }
    }
  }
}
